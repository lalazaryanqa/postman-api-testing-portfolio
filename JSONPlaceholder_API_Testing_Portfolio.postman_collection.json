  "item": [
    {
      "name": "GET Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains posts\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"First post has title\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData[0]).to.have.property(\"title\");\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"post_id\", jsonData[0].id);\r",
              "\r",
              "console.log(\"Saved post_id:\", jsonData[0].id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET Single Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains correct post ID\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData.id).to.eql(\r",
              "        Number(pm.environment.get(\"post_id\"))\r",
              "    );\r",
              "});\r",
              "\r",
              "pm.test(\"Post contains title\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData).to.have.property(\"title\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/{{post_id}}",
